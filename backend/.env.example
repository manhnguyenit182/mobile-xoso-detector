# ==========================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG BACKEND (SERVER)
# ==========================================

# 1. GOOGLE VISION API (Phục vụ OCR trích xuất ảnh)
# Truy cập Google Cloud Console -> APIs & Services -> Credentials để lấy key
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# 2. GEMINI AI API (Phục vụ phân tích văn bản siêu tốc)
# Truy cập Google AI Studio (https://aistudio.google.com/app/apikey) để lấy key
GEMINI_API_KEY=your_gemini_api_key_here

# 3. DATABASE POSTGRESQL (Cấu hình CSDL nếu triển khai Production)
# (Mặc định trong code đã có URL test, nhưng bạn có thể ghi đè biến này)
SPRING_DATASOURCE_URL=jdbc:postgresql://your_db_host:5432/your_db_name
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# Đổi properties spring.profiles.active=prod để sử dụng biến DB nếu cần.
