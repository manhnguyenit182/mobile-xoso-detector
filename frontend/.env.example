# ==========================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG FRONTEND (MOBILE)
# ==========================================

# ĐƯỜNG DẪN ĐẾN BACKEND SERVER CỦA BẠN
# Lưu ý: Các API Key (Google Vision, Gemini) đã được chuyển xuống Backend để BẢO MẬT.
# Frontend chỉ cần duy nhất đường dẫn này.

# Nếu bạn chạy localhost trên Emulator (Android): 
# EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:8080

# Nếu bạn chạy ngrok/localise cho điện thoại vật lý thật (Khuyên dùng khi debug cam):
EXPO_PUBLIC_BACKEND_URL=https://your-ngrok-url.ngrok-free.dev

# (Lưu ý: Không thêm dấu / ở cuối URL)
